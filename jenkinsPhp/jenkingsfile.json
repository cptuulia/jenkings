pipeline {
    agent any

       environment {
        DOCKER_IMAGE_NAME = "jenkinsphp-php" // Docker image name
        DOCKER_CONTAINER_NAME = "jenkins-php-pipeline" // Docker image version tag
        JENKINS_WORKSPACE_PATH="/var/jenkins_home/workspace/dddd/jenkinsPhp/code/"
    }

   
    stages {

        stage('Clone Repository') {
            steps {
                script {
                        sh 'pwd'  // Verify that the repository is cloned correctly
                        echo "Cloning repository from GitHub..."
                        git url: 'https://github.com/cptuulia/jenkings', branch: 'pipeline'

                        //echo "Listing workspace contents for verification..."
                        sh 'ls $JENKINS_WORKSPACE_PATH -la'  // Verify that the repository is cloned correctly                    
                }
            }
        }

    stage('Run container') {
            steps {
                script {
                    echo "Run Container $DOCKER_CONTAINER_NAME"
                    // We cannot use in the container the standard docker way to mount volume as below. We must copy the code
                    //sh 'docker run -d    --name jenkins-php-pipeline jenkinsphp-php'
                }
            }
        }

        stage('Copy code to the container') {
            steps {
                script {
                    echo "Copy php code to  $DOCKER_CONTAINER_NAME"
                    // The only known way to do it,is to compress the files to a tar file
                    // and copy it to the container and uncompress again
                    sh 'ls $JENKINS_WORKSPACE_PATH  '
                    sh 'cd $JENKINS_WORKSPACE_PATH; tar -czvf  example.tar . '
                    sh 'sleep 20 '
                  
                    sh 'docker run -d  --name jenkins-php-pipeline jenkinsphp-php'
                   
                    sh 'docker cp  $JENKINS_WORKSPACE_PATH/example.tar jenkins-php-pipeline:/var/www/  '
                    //sh 'rm  /var/jenkins_home/workspace/dddd/jenkinsPhp/code/example.tar'
                    //sh 'cd /var/jenkins_home/workspace/dddd/'

                    sh 'docker exec  jenkins-php-pipeline ls '
                    sh 'docker exec  jenkins-php-pipeline tar -xvf example.tar'
                    sh 'sleep 25'
                    echo "after copying php files"
                    sh 'docker exec  jenkins-php-pipeline ls '
                   
                    sh 'rm $JENKINS_WORKSPACE_PATH/example.tar  '
            
                 
                }
            }
        }
        stage('remove Container') {
            steps {
                script {
                    echo "Run php composer"
                  sh 'docker stop  $DOCKER_CONTAINER_NAME'
                    sh 'docker rm $DOCKER_CONTAINER_NAME'
                   
                }
            }
        }


    }
}